---
import Layout from "../layouts/Layout.astro";
import { RELEASES_URL } from "../lib/releases";

const CALENDLY_URL = "https://calendly.com/michael-getuno/30min";
---

<Layout>
  <section class="hero">
    <span class="eyebrow">AI that works with your machine</span>
    <h1 class="tagline">
      AI works on <em>your</em><br class="mobile-break" /> computer,<br class="desktop-break" /><br
        class="mobile-break"
      />
      with <em>your</em> files,<br class="mobile-break" /> under <em>your</em> control.
    </h1>
    <p class="subhead">
      Uno Work is local-first, with a built-in preview pane and optional remote power when you need it.
    </p>

    <div class="cta-row">
      <a
        href={CALENDLY_URL}
        class="hero-button"
        target="_blank"
        rel="noopener noreferrer"
      >
        <span>FREE demo</span>
      </a>

      <a href="/download/" class="other-platforms">Download</a>
    </div>
  </section>

  <section class="social-proof">
    <p class="social-eyebrow">Used by teams at</p>
    <ul class="social-list">
      <li class="social-item">
        <span class="social-mark social-mark--logo">
          <img src="/favicon.svg" alt="" aria-hidden="true" />
        </span>
        <span class="social-name">Uno</span>
      </li>
      <li class="social-item">
        <span class="social-mark social-mark--logo social-mark--unlimited">
          <img src="/logos/unlimited-ai.svg" alt="" aria-hidden="true" />
        </span>
        <span class="social-name">Unlimited&nbsp;AI</span>
      </li>
      <li class="social-item">
        <span class="social-mark social-mark--logo">
          <img src="/logos/ecorouter.svg" alt="" aria-hidden="true" />
        </span>
        <span class="social-name">EcoRouter</span>
      </li>
      <li class="social-item">
        <span class="social-mark social-mark--logo social-mark--productera">
          <img src="/logos/productera-mark.svg" alt="" aria-hidden="true" />
        </span>
        <span class="social-name">Productera</span>
      </li>
    </ul>
  </section>

  <div class="screenshot-wrap">
    <img
      src="/screenshots/hero.png"
      alt="Uno Work — projects sidebar, chat in the center, file preview pane on the right"
      class="screenshot"
    />
  </div>

  <section class="features">
    <div class="features-head">
      <span class="section-eyebrow">Everything in one workspace</span>
      <h2 class="section-title">A workspace, not a chat box.</h2>
      <p class="section-lead">
        Pick a harness. Pick a model. Drop in any file. Run on your machine or on a server — Uno Work
        handles the rest.
      </p>
    </div>

    <div class="features-grid">
      <article class="feature-mini">
        <div class="feature-mini-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
        </div>
        <h3 class="feature-mini-title">Any harness</h3>
        <p class="feature-mini-body">Claude Code, Codex, Cursor, Opencode — auto-detected. No re-auth.</p>
      </article>

      <article class="feature-mini">
        <div class="feature-mini-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 3v18"/><path d="M3 12h18"/></svg>
        </div>
        <h3 class="feature-mini-title">Any model</h3>
        <p class="feature-mini-body">300+ models via Uno LLM, or use the subscription you already pay for.</p>
      </article>

      <article class="feature-mini">
        <div class="feature-mini-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7z"/><circle cx="12" cy="12" r="3"/></svg>
        </div>
        <h3 class="feature-mini-title">Preview anything</h3>
        <p class="feature-mini-body">See PDFs, Excel, HTML, JSON, images, Markdown — right next to the chat.</p>
      </article>

      <article class="feature-mini">
        <div class="feature-mini-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="14" rx="2"/><path d="M8 20h8"/><path d="M12 18v2"/></svg>
        </div>
        <h3 class="feature-mini-title">Computer access</h3>
        <p class="feature-mini-body">Files, scripts, deploys, terminal. Real work, not just suggestions.</p>
      </article>

      <article class="feature-mini">
        <div class="feature-mini-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M3 12h18"/><path d="M12 3a14.5 14.5 0 0 1 0 18"/><path d="M12 3a14.5 14.5 0 0 0 0 18"/></svg>
        </div>
        <h3 class="feature-mini-title">Internet access</h3>
        <p class="feature-mini-body">Agents can fetch, browse, and integrate with anything online.</p>
      </article>

      <article class="feature-mini">
        <div class="feature-mini-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2 4 6v6c0 5 3.5 9.5 8 10 4.5-.5 8-5 8-10V6l-8-4z"/><path d="M9 12l2 2 4-4"/></svg>
        </div>
        <h3 class="feature-mini-title">Plugins &amp; skills</h3>
        <p class="feature-mini-body">Extend the agent with your own commands, skills, and integrations.</p>
      </article>

      <article class="feature-mini">
        <div class="feature-mini-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="12" rx="2"/><path d="M8 20h8"/><path d="M12 16v4"/><circle cx="7" cy="9" r="0.5" fill="currentColor"/><circle cx="7" cy="12" r="0.5" fill="currentColor"/></svg>
        </div>
        <h3 class="feature-mini-title">24/7 on a server</h3>
        <p class="feature-mini-body">Run agents headless on a VPS so they keep working while you sleep.</p>
      </article>

      <article class="feature-mini">
        <div class="feature-mini-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>
        </div>
        <h3 class="feature-mini-title">You're in control</h3>
        <p class="feature-mini-body">Approve actions per task or per session. Tighten or loosen any time.</p>
      </article>
    </div>
  </section>

  <section class="pricing">
    <div class="section-head">
      <span class="section-eyebrow">How to pay</span>
      <h2 class="section-title">The app is free. You only pay for tokens.</h2>
      <p class="section-lead">
        Uno Work itself is free forever. Tokens go through whoever you want — keep using the AI subscription
        you already have, or get them from us.
      </p>
    </div>

    <div class="pricing-grid">
      <article class="pricing-card">
        <h3 class="pricing-title">The app</h3>
        <p class="pricing-price">Free forever</p>
        <ul class="pricing-list">
          <li>macOS, Windows, Linux</li>
          <li>No accounts required</li>
          <li>Auto-updates</li>
        </ul>
        <a href={RELEASES_URL} class="pricing-cta">Download &rarr;</a>
      </article>

      <article class="pricing-card">
        <h3 class="pricing-title">Bring your own</h3>
        <p class="pricing-price">Your existing subscription</p>
        <ul class="pricing-list">
          <li>Claude Code, Codex, Cursor, Opencode</li>
          <li>Auto-detected — no re-auth</li>
          <li>Switch providers mid-thread</li>
        </ul>
        <a href="/download/" class="pricing-cta">Set it up &rarr;</a>
      </article>

      <article class="pricing-card pricing-card--featured">
        <span class="pricing-badge">Recommended</span>
        <h3 class="pricing-title">Uno LLM</h3>
        <p class="pricing-price">Pay as you go</p>
        <ul class="pricing-list">
          <li>One key, 300+ models</li>
          <li>OpenAI, Anthropic, Google, Mistral, Llama</li>
          <li>Works in regions where original providers are blocked</li>
        </ul>
        <a href="https://getuno.xyz/llm" target="_blank" rel="noopener noreferrer" class="pricing-cta pricing-cta--primary">Get a key &rarr;</a>
      </article>
    </div>
  </section>

  <section class="enterprise">
    <div class="enterprise-inner">
      <span class="section-eyebrow enterprise-eyebrow">For companies</span>
      <h2 class="enterprise-title">Uno Works on your infrastructure.</h2>
      <p class="enterprise-lead">
        Self-hosted, controlled, audited. We deliver the whole stack — workspace, identity,
        network, compute, models — and wire it into your systems.
      </p>

      <div class="enterprise-grid">
        <div class="enterprise-item">
          <h3 class="enterprise-item-title">Corporate identity (SSO)</h3>
          <p class="enterprise-item-body">Sign in with your IdP. Per-user access control and full audit trail.</p>
        </div>
        <div class="enterprise-item">
          <h3 class="enterprise-item-title">Self-hosted chats</h3>
          <p class="enterprise-item-body">Chat history stays on your servers. Requests proxied through your systems.</p>
        </div>
        <div class="enterprise-item">
          <h3 class="enterprise-item-title">Spend controls</h3>
          <p class="enterprise-item-body">Per-user and per-team budgets. Full usage audit across models and providers.</p>
        </div>
        <div class="enterprise-item">
          <h3 class="enterprise-item-title">Granular access</h3>
          <p class="enterprise-item-body">Control who sees which data, which knowledge bases, and which models.</p>
        </div>
        <div class="enterprise-item">
          <h3 class="enterprise-item-title">Dedicated workspaces</h3>
          <p class="enterprise-item-body">Sandboxed dev environments per engineer — no setup on their laptops.</p>
        </div>
        <div class="enterprise-item">
          <h3 class="enterprise-item-title">Private network</h3>
          <p class="enterprise-item-body">Agents reach your internal services over VPN, not the public internet.</p>
        </div>
        <div class="enterprise-item">
          <h3 class="enterprise-item-title">Dedicated compute</h3>
          <p class="enterprise-item-body">CPU and GPU servers in our DC or yours — for inference, fine-tuning, self-hosted models.</p>
        </div>
        <div class="enterprise-item">
          <h3 class="enterprise-item-title">LLM + your knowledge base</h3>
          <p class="enterprise-item-body">Custom deployments connected to your internal docs, codebases, and data.</p>
        </div>
        <div class="enterprise-item">
          <h3 class="enterprise-item-title">End-to-end rollout</h3>
          <p class="enterprise-item-body">Onboarding, training, support. We help your team actually use it, not just install it.</p>
        </div>
      </div>

      <div class="enterprise-cta">
        <button type="button" class="enterprise-button" id="sales-open">
          Talk to sales
          <span aria-hidden="true">&rarr;</span>
        </button>
        <div class="enterprise-contacts">
          <a href="https://t.me/get_uno_support" target="_blank" rel="noopener noreferrer" class="enterprise-link">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0Zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.231-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635Z"/></svg>
            t.me/get_uno_support
          </a>
          <a href="mailto:michael@getuno.xyz?subject=Uno%20Work%20for%20business" class="enterprise-link">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/></svg>
            michael@getuno.xyz
          </a>
        </div>
      </div>

      <dialog id="sales-dialog" class="sales-dialog">
        <button type="button" class="sales-dialog-close" id="sales-close" aria-label="Close">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
        </button>

        <div class="sales-dialog-inner">
          <span class="sales-eyebrow">Talk to sales</span>
          <h3 class="sales-title">Tell us about your team.</h3>
          <p class="sales-sub">
            We'll reply within one business day with a setup proposal — models, infra, access, rollout.
          </p>

          <form class="sales-form" id="sales-form">
            <div class="sales-form-row">
              <label>
                <span class="label-text">Name</span>
                <input type="text" name="name" required />
              </label>
              <label>
                <span class="label-text">Work email</span>
                <input type="email" name="email" required />
              </label>
            </div>

            <div class="sales-form-row">
              <label>
                <span class="label-text">Company</span>
                <input type="text" name="company" required />
              </label>
              <label>
                <span class="label-text">Team size</span>
                <select name="team_size" required>
                  <option value="">Select…</option>
                  <option>1-10</option>
                  <option>11-50</option>
                  <option>51-200</option>
                  <option>200+</option>
                </select>
              </label>
            </div>

            <div class="sales-group">
              <span class="label-text">What matters to you</span>
              <div class="sales-checks">
                <label class="check-item"><input type="checkbox" name="needs" value="Self-hosted in our perimeter" /><span>Self-hosted in our perimeter</span></label>
                <label class="check-item"><input type="checkbox" name="needs" value="Custom / private models" /><span>Custom or private models</span></label>
                <label class="check-item"><input type="checkbox" name="needs" value="SSO & granular access" /><span>SSO & granular access</span></label>
                <label class="check-item"><input type="checkbox" name="needs" value="Integration with internal infra" /><span>Integration with internal infra (repos, DBs, CI, tickets)</span></label>
                <label class="check-item"><input type="checkbox" name="needs" value="Sandboxed dev environments" /><span>Sandboxed dev environments per engineer</span></label>
                <label class="check-item"><input type="checkbox" name="needs" value="Spend controls & audit" /><span>Spend controls & full audit</span></label>
              </div>
            </div>

            <label>
              <span class="label-text">What do you want to do with Uno Work?</span>
              <textarea name="message" rows="4" required placeholder="Briefly — current stack, what you're trying to solve, timeline if any"></textarea>
            </label>

            <label>
              <span class="label-text">Preferred contact <span class="label-hint">(optional)</span></span>
              <input type="text" name="contact" placeholder="Telegram @, phone, or other" />
            </label>

            <button type="submit" class="sales-submit">Send</button>
            <p class="sales-note" id="sales-status" aria-live="polite">
              Sends your request to the Uno team. You can also write to
              <a href="mailto:michael@getuno.xyz?subject=Uno%20Work%20for%20business">michael@getuno.xyz</a>.
            </p>
          </form>
        </div>
      </dialog>
    </div>
  </section>

  <section class="final-cta">
    <h2 class="final-title">Free. Yours. Ready when you are.</h2>
    <p class="final-sub">Open the app, point it at a folder, start a conversation. That's the whole setup.</p>
    <a href={RELEASES_URL} class="hero-button">
      <span>Download Uno Work</span>
    </a>
    <a href="/download/" class="other-platforms">All platforms &amp; older versions</a>
  </section>
</Layout>

<script>
  const SALES_ENDPOINT = "https://uno-marketing-leads.shubaduba4th.workers.dev/lead";
  const dialog = document.getElementById("sales-dialog") as HTMLDialogElement | null;
  const openBtn = document.getElementById("sales-open");
  const closeBtn = document.getElementById("sales-close");
  const form = document.getElementById("sales-form") as HTMLFormElement | null;
  const status = document.getElementById("sales-status");
  const submit = form?.querySelector<HTMLButtonElement>(".sales-submit");

  openBtn?.addEventListener("click", () => dialog?.showModal());
  closeBtn?.addEventListener("click", () => dialog?.close());

  dialog?.addEventListener("click", (event) => {
    if (event.target === dialog) dialog.close();
  });

  form?.addEventListener("submit", async (event) => {
    event.preventDefault();
    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }

    const data = new FormData(form);
    const fields = {
      name: String(data.get("name") ?? "").trim(),
      email: String(data.get("email") ?? "").trim(),
      company: String(data.get("company") ?? "").trim(),
      team_size: String(data.get("team_size") ?? "").trim(),
      needs: data.getAll("needs").map(String).join(", "),
      message: String(data.get("message") ?? "").trim(),
      contact: String(data.get("contact") ?? "").trim(),
      source: window.location.href,
    };
    const payload = {
      type: "sales",
      fields,
    };

    if (submit) {
      submit.disabled = true;
      submit.textContent = "Sending...";
    }
    if (status) status.textContent = "Sending your request...";

    try {
      const response = await fetch(SALES_ENDPOINT, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload),
      });

      if (!response.ok) throw new Error(`Request failed: ${response.status}`);

      form.reset();
      if (status) status.textContent = "Sent. We'll get back to you shortly.";
      window.setTimeout(() => dialog?.close(), 900);
    } catch {
      const subject = fields.company
        ? `Uno Work for business — ${fields.company}`
        : "Uno Work for business";
      const body = [
        `Name: ${fields.name}`,
        `Email: ${fields.email}`,
        `Company: ${fields.company}`,
        `Team size: ${fields.team_size}`,
        "",
        fields.needs ? `What matters: ${fields.needs}` : "",
        fields.message ? `Goals / context:\n${fields.message}` : "",
        fields.contact ? `Preferred contact: ${fields.contact}` : "",
      ]
        .filter(Boolean)
        .join("\n");
      const mailto = `mailto:michael@getuno.xyz?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
      if (status) {
        status.innerHTML = `Could not send automatically. <a href="${mailto}">Email us instead</a>.`;
      }
    } finally {
      if (submit) {
        submit.disabled = false;
        submit.textContent = "Send";
      }
    }
  });
</script>

<style>
  /* ── Hero ── */

  .hero {
    width: 100%;
    max-width: 880px;
    padding: 7vh 1.5rem 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .eyebrow {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--uno-violet);
    background: var(--uno-violet-tint);
    border: 1px solid var(--uno-violet-border);
    padding: 0.35rem 0.75rem;
    border-radius: 999px;
    margin-bottom: 1.5rem;
    opacity: 0;
    animation: fade-in 0.8s ease-out forwards;
  }

  .tagline {
    font-weight: 600;
    font-size: clamp(2.1rem, 5vw, 3.5rem);
    letter-spacing: -0.025em;
    line-height: 1.1;
    max-width: 100%;
    margin: 0 0 1.25rem;
    opacity: 0;
    text-wrap: balance;
    animation: fade-in 1s ease-out 0.05s forwards;
  }

  .tagline em {
    font-style: normal;
    color: var(--uno-violet);
  }

  .mobile-break {
    display: none;
  }

  .subhead {
    font-size: clamp(1rem, 1.5vw, 1.125rem);
    line-height: 1.55;
    color: var(--text-muted);
    max-width: 640px;
    margin: 0 0 2.25rem;
    opacity: 0;
    animation: fade-in 1s ease-out 0.1s forwards;
  }

  .cta-row {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.85rem;
    margin-bottom: 4.5rem;
  }

  /* ── Hero button ── */

  .hero-button {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    background: var(--uno-violet);
    color: #fff;
    padding: 0.85rem 1.85rem;
    border-radius: 999px;
    font-weight: 600;
    font-size: 0.95rem;
    opacity: 0;
    animation: fade-in 1s ease-out 0.15s forwards;
    transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
    box-shadow: 0 4px 16px rgba(91, 91, 232, 0.25), 0 0 0 1px rgba(91, 91, 232, 0.15);
  }

  .hero-button:hover {
    transform: translateY(-1px);
    background: var(--uno-violet-soft);
    box-shadow: 0 8px 24px rgba(91, 91, 232, 0.35), 0 0 0 1px rgba(91, 91, 232, 0.2);
  }

  .hero-button:active {
    transform: translateY(0);
  }

  /* ── Other platforms link ── */

  .other-platforms {
    font-size: 0.825rem;
    color: var(--text-muted);
    opacity: 0;
    animation: fade-in 1s ease-out 0.25s forwards;
    transition: color 0.2s ease;
    text-decoration: underline;
    text-decoration-color: var(--line-strong);
    text-underline-offset: 3px;
  }

  .other-platforms:hover {
    color: var(--text);
    text-decoration-color: var(--text);
  }

  /* ── Screenshot ── */

  .screenshot-wrap {
    margin: 0 auto;
    width: min(95vw, 1280px);
    padding: 0 1rem;
    opacity: 0;
    transform: scale(0.985);
    animation: screenshot-in 1s ease-out 0.2s forwards;
  }

  .screenshot {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 14px;
    border: 1px solid var(--line);
    box-shadow:
      0 30px 80px rgba(20, 20, 30, 0.12),
      0 8px 24px rgba(20, 20, 30, 0.06);
    background: var(--bg-panel);
  }

  @keyframes screenshot-in {
    from {
      opacity: 0;
      transform: scale(0.985);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }

