          <p class="enterprise-item-body">CPU and GPU servers in our DC or yours — for inference, fine-tuning, self-hosted models.</p>
        </div>
        <div class="enterprise-item">
          <h3 class="enterprise-item-title">LLM + your knowledge base</h3>
          <p class="enterprise-item-body">Custom deployments connected to your internal docs, codebases, and data.</p>
        </div>
        <div class="enterprise-item">
          <h3 class="enterprise-item-title">End-to-end rollout</h3>
          <p class="enterprise-item-body">Onboarding, training, support. We help your team actually use it, not just install it.</p>
        </div>
      </div>

      <div class="enterprise-cta">
        <a href="https://t.me/get_uno_support" target="_blank" rel="noopener noreferrer" class="enterprise-button">
          Talk to sales
          <span aria-hidden="true">&rarr;</span>
        </a>
        <div class="enterprise-contacts">
          <a href="https://t.me/get_uno_support" target="_blank" rel="noopener noreferrer" class="enterprise-link">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0Zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.231-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635Z"/></svg>
            t.me/get_uno_support
          </a>
          <a href="mailto:michael@getuno.xyz?subject=Uno%20Work%20for%20business" class="enterprise-link">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/></svg>
            michael@getuno.xyz
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="final-cta">
    <h2 class="final-title">Free. Yours. Ready when you are.</h2>
    <p class="final-sub">Open the app, point it at a folder, start a conversation. That's the whole setup.</p>
    <a href={RELEASES_URL} class="hero-button">
      <span>Download Uno Work</span>
    </a>
    <a href="/download" class="other-platforms">All platforms &amp; older versions</a>
  </section>
</Layout>

<script>
  import { fetchLatestRelease, pickReleaseAsset, RELEASES_URL, type ReleasePlatform } from "../lib/releases";

  type Platform = { os: "mac" | "win" | "linux"; label: string; releasePlatform: ReleasePlatform };

  function detectPlatform(): Platform | null {
    const ua = navigator.userAgent;
    if (/Win/i.test(ua)) {
      return { os: "win", label: "Download for Windows", releasePlatform: "win-x64" };
    }
    if (/Mac/i.test(ua)) {
      return {
        os: "mac",
        label: `Download for macOS`,
        releasePlatform: "mac-arm64",
      };
    }
    if (/Linux/i.test(ua)) {
      return { os: "linux", label: "Download for Linux", releasePlatform: "linux-x64" };
    }
    return null;
  }

  async function init() {
    const btn = document.getElementById("download-btn") as HTMLAnchorElement | null;
    const label = document.getElementById("download-label");
    if (!btn || !label) return;

    const platform = detectPlatform();
    if (!platform) return;

    document.documentElement.dataset.platform = platform.os;
    label.textContent = platform.label;

    try {
      const release = await fetchLatestRelease();
      const asset = pickReleaseAsset(release.assets ?? [], platform.releasePlatform);
      if (asset) {
        btn.href = asset.browser_download_url;
        btn.removeAttribute("target");
        btn.removeAttribute("rel");
      }
    } catch {
      btn.href = RELEASES_URL;
    }
  }

  init();
</script>

<style>
  /* ── Hero ── */

  .hero {
    width: 100%;
    max-width: 880px;
    padding: 7vh 1.5rem 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .eyebrow {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--uno-violet);
    background: var(--uno-violet-tint);
    border: 1px solid var(--uno-violet-border);
    padding: 0.35rem 0.75rem;
    border-radius: 999px;
    margin-bottom: 1.5rem;
    opacity: 0;
    animation: fade-in 0.8s ease-out forwards;
  }

  .tagline {
    font-weight: 600;
    font-size: clamp(2.1rem, 5vw, 3.5rem);
    letter-spacing: -0.025em;
    line-height: 1.1;
    max-width: 100%;
    margin: 0 0 1.25rem;
    opacity: 0;
    text-wrap: balance;
    animation: fade-in 1s ease-out 0.05s forwards;
  }

  .tagline em {
    font-style: normal;
    color: var(--uno-violet);
  }

  .mobile-break {
    display: none;
  }

  .subhead {
    font-size: clamp(1rem, 1.5vw, 1.125rem);
    line-height: 1.55;
    color: var(--text-muted);
    max-width: 640px;
    margin: 0 0 2.25rem;
    opacity: 0;
    animation: fade-in 1s ease-out 0.1s forwards;
  }

  .cta-row {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.85rem;
    margin-bottom: 4.5rem;
  }

  /* ── Hero button ── */

  .hero-button {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    background: var(--uno-violet);
    color: #fff;
    padding: 0.85rem 1.85rem;
    border-radius: 999px;
    font-weight: 600;
    font-size: 0.95rem;
    opacity: 0;
    animation: fade-in 1s ease-out 0.15s forwards;
    transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
    box-shadow: 0 4px 16px rgba(91, 91, 232, 0.25), 0 0 0 1px rgba(91, 91, 232, 0.15);
  }

  .hero-button:hover {
    transform: translateY(-1px);
    background: var(--uno-violet-soft);
    box-shadow: 0 8px 24px rgba(91, 91, 232, 0.35), 0 0 0 1px rgba(91, 91, 232, 0.2);
  }

  .hero-button:active {
    transform: translateY(0);
  }

  .hero-button-icon {
    display: none;
    width: 1em;
    height: 1em;
    flex-shrink: 0;
  }

  :global([data-platform="mac"]) .hero-button-icon--apple {
    display: block;
  }

  :global([data-platform="win"]) .hero-button-icon--windows {
    display: block;
  }

  :global([data-platform="linux"]) .hero-button-icon--linux {
    display: block;
  }

  /* ── Other platforms link ── */

  .other-platforms {
    font-size: 0.825rem;
    color: var(--text-muted);
    opacity: 0;
    animation: fade-in 1s ease-out 0.25s forwards;
    transition: color 0.2s ease;
    text-decoration: underline;
    text-decoration-color: var(--line-strong);
    text-underline-offset: 3px;
  }

  .other-platforms:hover {
    color: var(--text);
    text-decoration-color: var(--text);
  }

  /* ── Screenshot ── */

  .screenshot-wrap {
    margin: 0 auto;
    width: min(95vw, 1280px);
    padding: 0 1rem;
    opacity: 0;
    transform: scale(0.985);
    animation: screenshot-in 1s ease-out 0.2s forwards;
  }

  .screenshot {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 14px;
    border: 1px solid var(--line);
    box-shadow:
      0 30px 80px rgba(20, 20, 30, 0.12),
      0 8px 24px rgba(20, 20, 30, 0.06);
    background: var(--bg-panel);
  }

  @keyframes screenshot-in {
    from {
      opacity: 0;
      transform: scale(0.985);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }

  /* ── Section common ── */

  .section-eyebrow {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--uno-violet);
    margin-bottom: 0.85rem;
  }

  .section-title {
    font-weight: 600;
    font-size: clamp(1.6rem, 3.5vw, 2.4rem);
    letter-spacing: -0.02em;
    line-height: 1.15;
    margin-bottom: 0.85rem;
    color: var(--text);
  }

  .section-lead {
    font-size: 1rem;
    line-height: 1.6;
    color: var(--text-muted);
    max-width: 640px;
  }

  .section-head {
    text-align: center;
    margin: 0 auto 3rem;
    max-width: 680px;
  }

  .section-head .section-lead {
    margin: 0 auto;
  }

  /* ── Social Proof ── */

  .social-proof {
    width: min(95vw, 980px);
    margin: 3rem auto 4rem;
    padding: 0 1rem;
    text-align: center;
  }

  .social-eyebrow {
    font-size: 0.72rem;
