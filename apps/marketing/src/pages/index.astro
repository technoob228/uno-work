---
import Layout from "../layouts/Layout.astro";
import { RELEASES_URL } from "../lib/releases";
---

<Layout>
  <section class="hero">
    <span class="eyebrow">AI that works with your machine</span>
    <h1 class="tagline">
      AI works on <em>your</em><br class="mobile-break" /> computer,<br class="desktop-break" /><br
        class="mobile-break"
      />
      with <em>your</em> files,<br class="mobile-break" /> under <em>your</em> control.
    </h1>
    <p class="subhead">
      Uno Work is local-first, with a built-in preview pane and optional remote power when you need it.
    </p>

    <div class="cta-row">
      <a
        id="download-btn"
        href={RELEASES_URL}
        class="hero-button"
      >
        <svg class="hero-button-icon hero-button-icon--apple" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 814 1000" aria-hidden="true"><path fill="currentColor" d="M788.1 340.9c-5.8 4.5-108.2 62.2-108.2 190.5 0 148.4 130.3 200.9 134.2 202.2-.6 3.2-20.7 71.9-68.7 141.9-42.8 61.6-87.5 123.1-155.5 123.1s-85.5-39.5-164-39.5c-76.5 0-103.7 40.8-165.9 40.8s-105.6-57-155.5-127C46.7 790.7 0 663 0 541.8c0-194.4 126.4-297.5 250.8-297.5 66.1 0 121.2 43.4 162.7 43.4 39.5 0 101.1-46 176.3-46 28.5 0 130.9 2.6 198.3 99.2zm-234-181.5c31.1-36.9 53.1-88.1 53.1-139.3 0-7.1-.6-14.3-1.9-20.1-50.6 1.9-110.8 33.7-147.1 75.8-28.5 32.4-55.1 83.6-55.1 135.5 0 7.8 1.3 15.6 1.9 18.1 3.2.6 8.4 1.3 13.6 1.3 45.4 0 102.5-30.4 135.5-71.3z"/></svg>
        <svg class="hero-button-icon hero-button-icon--windows" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 88 88" aria-hidden="true"><path fill="currentColor" d="m0 12.402 35.687-4.86.016 34.423-35.67.203zm35.67 33.529.028 34.453L.028 75.48.026 45.7zm4.326-39.025L87.314 0v41.527l-47.318.376zm47.329 39.349-.011 41.34-47.318-6.678-.066-34.739z"/></svg>
        <svg class="hero-button-icon hero-button-icon--linux" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M12.504 0c-.155 0-.315.008-.48.021-4.226.333-3.105 4.807-3.17 6.298-.076 1.092-.3 1.953-1.05 3.02-.885 1.051-2.127 2.75-2.716 4.521-.278.832-.41 1.684-.287 2.489a.424.424 0 0 0-.11.135c-.26.268-.45.6-.663.839-.199.199-.485.267-.797.4-.313.136-.658.269-.864.68-.09.189-.136.394-.132.602 0 .199.027.4.055.536.058.399.116.728.04.97-.249.68-.28 1.145-.106 1.484.174.334.535.47.94.601.81.2 1.91.135 2.774.6.926.466 1.866.67 2.616.47.526-.116.97-.464 1.208-.946.587-.003 1.23-.269 2.26-.334.699-.058 1.574.267 2.577.2.025.134.063.198.114.333l.003.003c.391.778 1.113 1.132 1.884 1.071.771-.06 1.592-.536 2.257-1.306.631-.765 1.683-1.084 2.378-1.503.348-.199.629-.469.649-.853.023-.4-.2-.811-.714-1.376z"/></svg>
        <span id="download-label">Download now</span>
      </a>

      <a href="/download" class="other-platforms">Other platforms</a>
    </div>
  </section>

  <section class="social-proof">
    <p class="social-eyebrow">Used by teams at</p>
    <ul class="social-list">
      <li class="social-item">
        <span class="social-mark social-mark--logo">
          <img src="/favicon.svg" alt="" aria-hidden="true" />
        </span>
        <span class="social-name">Uno</span>
      </li>
      <li class="social-item">
        <span class="social-mark social-mark--logo social-mark--unlimited">
          <img src="/logos/unlimited-ai.svg" alt="" aria-hidden="true" />
        </span>
        <span class="social-name">Unlimited&nbsp;AI</span>
      </li>
      <li class="social-item">
        <span class="social-mark social-mark--logo">
          <img src="/logos/ecorouter.svg" alt="" aria-hidden="true" />
        </span>
        <span class="social-name">EcoRouter</span>
      </li>
      <li class="social-item">
        <span class="social-mark social-mark--logo social-mark--productera">
