---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Careers — Uno Work"
  description="Join Uno Work — building a local-first AI workspace."
>
  <section class="careers-hero">
    <span class="eyebrow">Careers</span>
    <h1 class="careers-title">
      Help build a workspace where AI <em>actually</em> works.
    </h1>
    <p class="careers-sub">
      We're a small team building Uno Work — a local-first AI workspace.
      Two roles open. If you're great and you fit, we move fast.
    </p>
  </section>

  <section class="jobs">
    <details class="job" id="builder">
      <summary class="job-summary">
        <div class="job-summary-left">
          <span class="job-badge">Product · Engineering</span>
          <h2 class="job-title">Builder / AI Product Manager</h2>
          <p class="job-snippet">CLI-first. SaaS background. You ship product, not decks.</p>
        </div>
        <div class="job-summary-right">
          <span class="job-meta">Full-time · Remote</span>
          <span class="job-toggle" aria-hidden="true"></span>
        </div>
      </summary>

      <div class="job-body">
        <div class="job-content">
          <div class="job-section">
            <h3>About the role</h3>
            <p>
              You'll own product development at Uno Work — sitting between
              engineering, design, and the AI coding agents themselves. Most
              of your day looks like driving CLI-based AI tools (Claude Code,
              Codex, Cursor, Opencode) to ship real product, then turning what
              works into specs the rest of the team can scale.
            </p>
          </div>

          <div class="job-section">
            <h3>Requirements</h3>
            <ul>
              <li>Comfortable living in CLI-based AI coding tools — you have a real workflow, not just curiosity</li>
              <li>1+ year as a developer, product manager, or business analyst in SaaS</li>
              <li>Strong product instincts — you can write a spec, scope a release, and cut features</li>
              <li>English or Russian at native level</li>
            </ul>
          </div>

          <div class="job-section">
            <h3>Nice to have</h3>
            <ul>
              <li>Built or shipped something on top of LLMs (agents, copilots, internal tools)</li>
              <li>Background in dev-tools, infra, or productivity software</li>
            </ul>
          </div>
        </div>

        <form class="apply-form" data-form="builder" data-role="Builder / AI Product Manager">
          <h3 class="form-title">Apply for this role</h3>

          <div class="form-row">
            <label>
              <span class="label-text">Name</span>
              <input type="text" name="name" required />
            </label>
            <label>
              <span class="label-text">Email</span>
              <input type="email" name="email" required />
            </label>
          </div>

          <label>
            <span class="label-text">LinkedIn</span>
            <input type="url" name="linkedin" placeholder="https://linkedin.com/in/..." />
          </label>

          <label>
            <span class="label-text">GitHub</span>
            <input type="url" name="github" placeholder="https://github.com/..." />
          </label>

          <label>
            <span class="label-text">Resume <span class="label-hint">(link to PDF / Google Drive / Notion)</span></span>
            <input type="url" name="resume" required placeholder="https://..." />
          </label>

          <label>
            <span class="label-text">
              Link to your best Minecraft project
              <span class="required" aria-hidden="true">*</span>
            </span>
            <input
              type="url"
              name="minecraft"
              required
              placeholder="A build, a server, a mod, a screenshot — anything"
            />
            <small class="field-hint">Yes, this is required. Yes, we will look at it.</small>
          </label>

          <label>
            <span class="label-text">Why this role?</span>
            <textarea name="message" rows="4" required></textarea>
          </label>

          <button type="submit" class="form-submit">Send application</button>
          <p class="form-note">
            Opens your mail client with everything pre-filled. Or write to
            <a href="mailto:careers@getuno.xyz">careers@getuno.xyz</a> directly.
          </p>
        </form>
      </div>
    </details>

    <details class="job" id="commerce">
      <summary class="job-summary">
        <div class="job-summary-left">
          <span class="job-badge">Commerce</span>
          <h2 class="job-title">Commerce / BDM</h2>
          <p class="job-snippet">Partnerships, outreach, deals that actually close.</p>
        </div>
        <div class="job-summary-right">
          <span class="job-meta">Full-time · Remote</span>
          <span class="job-toggle" aria-hidden="true"></span>
        </div>
      </summary>

      <div class="job-body">
        <div class="job-content">
          <div class="job-section">
            <h3>About the role</h3>
            <p>
              You'll own the commercial side at Uno Work — partnerships with
              clients, promoters, and integrators. Outreach, deal flow, and
              turning warm conversations into actual revenue.
            </p>
          </div>

          <div class="job-section">
            <h3>Requirements</h3>
            <ul>
              <li>1+ year of commercial experience (sales, BDM, partnerships, or growth)</li>
              <li>Comfortable cold-reaching out — email, LinkedIn, Telegram, in person</li>
              <li>English B2+ (written and spoken)</li>
              <li>Organized — CRM hygiene, pipeline tracking, follow-ups that don't slip</li>
            </ul>
          </div>

          <div class="job-section">
            <h3>Nice to have</h3>
            <ul>
              <li>Experience selling dev-tools, SaaS, or AI products</li>
              <li>Existing network in AI / dev / infra communities</li>
            </ul>
          </div>
        </div>

        <form class="apply-form" data-form="commerce" data-role="Commerce / BDM">
          <h3 class="form-title">Apply for this role</h3>

          <div class="form-row">
            <label>
              <span class="label-text">Name</span>
              <input type="text" name="name" required />
            </label>
            <label>
              <span class="label-text">Email</span>
              <input type="email" name="email" required />
            </label>
          </div>

          <label>
            <span class="label-text">LinkedIn</span>
            <input type="url" name="linkedin" required placeholder="https://linkedin.com/in/..." />
          </label>

          <label>
            <span class="label-text">Resume <span class="label-hint">(link to PDF / portfolio)</span></span>
            <input type="url" name="resume" required placeholder="https://..." />
          </label>

          <label>
            <span class="label-text">A deal or partnership you closed</span>
            <textarea name="deal" rows="3" required placeholder="1-2 sentences, no need to dress it up"></textarea>
          </label>

          <label>
            <span class="label-text">Why Uno Work?</span>
            <textarea name="message" rows="4" required></textarea>
          </label>

          <button type="submit" class="form-submit">Send application</button>
          <p class="form-note">
            Opens your mail client with everything pre-filled. Or write to
            <a href="mailto:careers@getuno.xyz">careers@getuno.xyz</a> directly.
          </p>
        </form>
      </div>
    </details>
  </section>

  <section class="careers-other">
    <p>
      Don't see a role for you?
      <a href="mailto:careers@getuno.xyz">Email us anyway</a> — if you're great, we'll find a way.
    </p>
  </section>
</Layout>

<script>
  function buildMailto(form: HTMLFormElement): string {
    const role = form.dataset.role ?? "Unknown role";
    const data = new FormData(form);

    const labels: Record<string, string> = {
      name: "Name",
      email: "Email",
      linkedin: "LinkedIn",
      github: "GitHub",
      resume: "Resume",
      minecraft: "Best Minecraft project",
      deal: "Deal / partnership closed",
      message: "Why",
    };

    const lines: string[] = [`Role: ${role}`, ""];
    for (const [key, raw] of data.entries()) {
      const value = String(raw).trim();
      if (!value) continue;
      const label = labels[key] ?? key;
      lines.push(`${label}:`, value, "");
    }

    const name = String(data.get("name") ?? "").trim() || "Candidate";
    const subject = `Application — ${role} — ${name}`;
    const body = lines.join("\n");

    return `mailto:careers@getuno.xyz?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
  }

  document.querySelectorAll<HTMLFormElement>(".apply-form").forEach((form) => {
    form.addEventListener("submit", (event) => {
      event.preventDefault();
      if (!form.checkValidity()) {
        form.reportValidity();
        return;
      }
      window.location.href = buildMailto(form);
    });
  });

  if (window.location.hash) {
    const target = document.querySelector(window.location.hash);
    if (target instanceof HTMLDetailsElement) {
      target.open = true;
      target.scrollIntoView({ behavior: "smooth", block: "start" });
    }
  }
</script>

<style>
  .careers-hero {
    width: 100%;
    max-width: 760px;
    padding: 6vh 1.5rem 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .eyebrow {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--uno-violet);
    background: var(--uno-violet-tint);
    border: 1px solid var(--uno-violet-border);
    padding: 0.35rem 0.75rem;
    border-radius: 999px;
    margin-bottom: 1.5rem;
    opacity: 0;
    animation: fade-in 0.8s ease-out forwards;
  }

  .careers-title {
    font-weight: 600;
    font-size: clamp(2rem, 4.5vw, 3rem);
    letter-spacing: -0.025em;
    line-height: 1.1;
    margin: 0 0 1.25rem;
    text-wrap: balance;
    opacity: 0;
    animation: fade-in 1s ease-out 0.05s forwards;
  }

  .careers-title em {
    font-style: normal;
    color: var(--uno-violet);
  }

  .careers-sub {
    font-size: clamp(1rem, 1.5vw, 1.125rem);
    line-height: 1.6;
    color: var(--text-muted);
    max-width: 580px;
    margin: 0;
    opacity: 0;
    animation: fade-in 1s ease-out 0.1s forwards;
  }

  .jobs {
    width: min(95vw, 880px);
    margin: 4rem auto 0;
    padding: 0 1rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .job {
    background: var(--bg-panel);
    border: 1px solid var(--line);
    border-radius: var(--radius-xl);
    overflow: hidden;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .job:hover {
    border-color: var(--uno-violet-border);
  }

  .job[open] {
    border-color: var(--uno-violet-border);
    box-shadow: 0 8px 28px rgba(91, 91, 232, 0.08);
  }

  .job-summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.25rem;
    padding: 1.5rem 1.75rem;
    cursor: pointer;
    list-style: none;
  }

  .job-summary::-webkit-details-marker {
    display: none;
  }

  .job-summary-left {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    min-width: 0;
  }

  .job-badge {
    display: inline-block;
    font-size: 0.66rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--uno-violet);
    background: var(--uno-violet-tint);
    border: 1px solid var(--uno-violet-border);
    padding: 0.2rem 0.55rem;
    border-radius: 999px;
    width: max-content;
  }

  .job-title {
    font-size: 1.2rem;
    font-weight: 600;
    letter-spacing: -0.015em;
    color: var(--text);
    margin: 0.15rem 0 0;
  }

  .job-snippet {
    font-size: 0.88rem;
    color: var(--text-muted);
    margin: 0;
  }

  .job-summary-right {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-shrink: 0;
  }

  .job-meta {
    font-size: 0.78rem;
    color: var(--text-faint);
    white-space: nowrap;
  }

  .job-toggle {
    width: 28px;
    height: 28px;
    border-radius: 8px;
    background: var(--uno-violet-tint);
    color: var(--uno-violet);
    display: grid;
    place-items: center;
    position: relative;
    transition: transform 0.25s ease, background 0.2s ease;
  }

  .job-toggle::before,
  .job-toggle::after {
    content: "";
    position: absolute;
    background: currentColor;
    border-radius: 1px;
    transition: transform 0.25s ease, opacity 0.25s ease;
  }

  .job-toggle::before {
    width: 12px;
    height: 2px;
  }

  .job-toggle::after {
    width: 2px;
    height: 12px;
  }

  .job[open] .job-toggle {
    background: var(--uno-violet);
    color: #fff;
  }

  .job[open] .job-toggle::after {
    transform: scaleY(0);
    opacity: 0;
  }

  .job-body {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: 2rem;
    padding: 0 1.75rem 1.75rem;
    border-top: 1px solid var(--line);
    padding-top: 1.75rem;
  }

  .job-content {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .job-section h3 {
    font-size: 0.78rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-faint);
    margin-bottom: 0.5rem;
  }

  .job-section p {
    font-size: 0.93rem;
    line-height: 1.6;
    color: var(--text-muted);
  }

  .job-section ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .job-section li {
    font-size: 0.92rem;
    line-height: 1.55;
    color: var(--text-muted);
    padding-left: 1.1rem;
    position: relative;
  }

  .job-section li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.6rem;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--uno-violet);
  }

  /* ── Apply form ── */

  .apply-form {
    background: var(--bg-subtle);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    align-self: start;
  }

  .form-title {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text);
    margin: 0 0 0.25rem;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.65rem;
  }

  .apply-form label {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    font-size: 0.82rem;
    color: var(--text);
  }

  .label-text {
    font-weight: 500;
    color: var(--text);
  }

  .label-hint {
    font-weight: 400;
    color: var(--text-faint);
  }

  .required {
    color: var(--uno-violet);
    font-weight: 700;
    margin-left: 0.15rem;
  }

  .apply-form input,
  .apply-form textarea {
    font: inherit;
    font-size: 0.88rem;
    color: var(--text);
    background: var(--bg-panel);
    border: 1px solid var(--line-strong);
    border-radius: 8px;
    padding: 0.6rem 0.75rem;
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
    width: 100%;
  }

  .apply-form textarea {
    resize: vertical;
    min-height: 80px;
    font-family: inherit;
  }

  .apply-form input:focus,
  .apply-form textarea:focus {
    outline: none;
    border-color: var(--uno-violet);
    box-shadow: 0 0 0 3px var(--uno-violet-tint);
  }

  .apply-form input::placeholder,
  .apply-form textarea::placeholder {
    color: var(--text-faint);
  }

  .field-hint {
    font-size: 0.75rem;
    color: var(--text-faint);
    line-height: 1.4;
  }

  .form-submit {
    margin-top: 0.4rem;
    background: var(--uno-violet);
    color: #fff;
    border: none;
    padding: 0.8rem 1.5rem;
    border-radius: 999px;
    font-weight: 600;
    font-size: 0.92rem;
    cursor: pointer;
    font-family: inherit;
    transition: background 0.15s ease, transform 0.15s ease, box-shadow 0.15s ease;
    box-shadow: 0 4px 14px rgba(91, 91, 232, 0.25);
  }

  .form-submit:hover {
    background: var(--uno-violet-soft);
    transform: translateY(-1px);
    box-shadow: 0 8px 20px rgba(91, 91, 232, 0.32);
  }

  .form-submit:active {
    transform: translateY(0);
  }

  .form-note {
    font-size: 0.75rem;
    color: var(--text-faint);
    line-height: 1.5;
    margin: 0;
  }

  .form-note a {
    color: var(--uno-violet);
    text-decoration: underline;
    text-decoration-color: var(--uno-violet-border);
    text-underline-offset: 2px;
  }

  .form-note a:hover {
    text-decoration-color: var(--uno-violet);
  }

  /* ── Other ── */

  .careers-other {
    width: 100%;
    max-width: 720px;
    margin: 4rem auto 6rem;
    padding: 0 1.5rem;
    text-align: center;
  }

  .careers-other p {
    font-size: 0.95rem;
    color: var(--text-muted);
  }

  .careers-other a {
    color: var(--uno-violet);
    text-decoration: underline;
    text-decoration-color: var(--uno-violet-border);
    text-underline-offset: 3px;
    transition: text-decoration-color 0.15s ease;
  }

  .careers-other a:hover {
    text-decoration-color: var(--uno-violet);
  }

  /* ── Mobile ── */

  @media (max-width: 860px) {
    .job-body {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
  }

  @media (max-width: 640px) {
    .careers-hero {
      padding-top: 4vh;
    }

    .jobs {
      width: 100%;
      padding: 0 1rem;
    }

    .job-summary {
      padding: 1.25rem 1.25rem;
      gap: 0.85rem;
    }

    .job-summary-right {
      gap: 0.5rem;
      flex-direction: column;
      align-items: flex-end;
    }

    .job-meta {
      font-size: 0.72rem;
    }

    .job-title {
      font-size: 1.05rem;
    }

    .job-body {
      padding: 1.25rem;
    }

    .form-row {
      grid-template-columns: 1fr;
    }
  }
</style>
