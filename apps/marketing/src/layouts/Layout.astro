---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Uno Work - AI that works with your machine",
  description = "Uno Work — AI that works with your machine. Local-first, with a built-in preview pane and optional remote power.",
} = Astro.props;

const siteUrl = "https://uno4.work";
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString();
const socialImageUrl = new URL("/screenshot.jpeg", siteUrl).toString();
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#5B5BE8" />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Uno Work" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={socialImageUrl} />
    <meta property="og:image:alt" content="Uno Work app interface with projects, chat, and file preview" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImageUrl} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" sizes="48x48" />
    <link rel="icon" type="image/png" href="/favicon-32x32.png" sizes="32x32" />
    <link rel="icon" type="image/png" href="/favicon-16x16.png" sizes="16x16" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <title>{title}</title>
  </head>
  <body>
    <div class="page">
      <nav class="nav">
        <a href="/" class="nav-brand">
          <span class="brand-mark" aria-hidden="true">U</span>
          <span class="brand-text">Uno Work</span>
        </a>
        <a
          href="https://github.com/technoob228/uno-work"
          target="_blank"
          rel="noopener noreferrer"
          class="nav-github"
        >
          GitHub
          <span class="nav-github-arrow" aria-hidden="true">&#8599;</span>
        </a>
      </nav>

      <main class="main">
        <slot />
      </main>

      <footer class="footer">
        <span class="footer-copy">&copy; {new Date().getFullYear()} Uno</span>
        <div class="footer-links">
          <a href="https://github.com/technoob228/uno-work" target="_blank" rel="noopener noreferrer">GitHub</a>
          <a href="https://getuno.xyz" target="_blank" rel="noopener noreferrer">getuno.xyz</a>
        </div>
      </footer>
    </div>
  </body>
</html>

<style is:global>
  :root {
    --bg: #FAFAFB;
    --bg-panel: #FFFFFF;
    --bg-subtle: #F4F4F7;
    --text: #18181B;
    --text-muted: #6B6B75;
    --text-faint: #9999A1;
    --line: #ECECF0;
    --line-strong: #DEDEE4;
    --uno-violet: #5B5BE8;
    --uno-violet-soft: #6E6EF0;
    --uno-violet-tint: #EEEEFB;
    --uno-violet-border: #DDDDF7;
    --radius: 8px;
    --radius-lg: 12px;
    --radius-xl: 16px;
  }

  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    color-scheme: light;
  }

  body {
    color: var(--text);
    font-family: "Inter", -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui, sans-serif;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    min-height: 100vh;
    overflow-x: hidden;
    background:
      radial-gradient(1200px 600px at 20% 0%, #E9E9FB 0%, transparent 50%),
      radial-gradient(900px 500px at 90% 100%, #F0E9FB 0%, transparent 50%),
      var(--bg);
    background-attachment: fixed;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  img {
    display: block;
    max-width: 100%;
  }

  @keyframes fade-in {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

<style>
  .page {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    overflow-x: hidden;
  }

  /* ── Navbar ── */

  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.25rem 2.5rem;
  }

  .nav-brand {
    display: flex;
    align-items: center;
    gap: 0.55rem;
  }

  .brand-mark {
    width: 26px;
    height: 26px;
    border-radius: 7px;
    background: linear-gradient(135deg, var(--uno-violet) 0%, #8C8CFF 100%);
    color: #fff;
    font-weight: 700;
    font-size: 13px;
    display: grid;
    place-items: center;
    box-shadow: 0 1px 2px rgba(91, 91, 232, 0.35), inset 0 1px 0 rgba(255, 255, 255, 0.4);
  }

  .brand-text {
    font-weight: 600;
    font-size: 0.95rem;
    letter-spacing: -0.01em;
    color: var(--text);
  }

  .nav-github {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    color: var(--text-muted);
    font-size: 0.875rem;
    font-weight: 500;
    transition: color 0.2s ease;
  }

  .nav-github:hover {
    color: var(--text);
  }

  .nav-github-arrow {
    display: inline-block;
    transition: transform 0.25s ease;
  }

  .nav-github:hover .nav-github-arrow {
    transform: translateX(2px) translateY(-1px);
  }

  /* ── Main content ── */

  .main {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  /* ── Footer ── */

  .footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.5rem 2.5rem;
    font-size: 0.8rem;
    color: var(--text-faint);
  }

  .footer-links {
    display: flex;
    gap: 1.25rem;
  }

  .footer-links a {
    color: var(--text-faint);
    transition: color 0.2s ease;
  }

  .footer-links a:hover {
    color: var(--text);
  }

  /* ── Mobile ── */

  @media (max-width: 640px) {
    .nav {
      padding: 1rem 1.25rem;
    }

    .footer {
      padding: 1.25rem;
      flex-direction: column;
      gap: 0.5rem;
    }
  }
</style>
